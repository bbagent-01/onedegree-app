# Environment variables template — copy to .env.local and fill in.
# .env.local is gitignored (see .gitignore).

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Supabase (DB)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Only needed for running migrations locally.
SUPABASE_ACCESS_TOKEN=

# Resend (email)
RESEND_API_KEY=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Misc
SIGNUP_MODE=
NEXT_PUBLIC_APP_URL=
CRON_SECRET=

# ──────────────────────────────────────────────────────────────
# Impersonation — ALPHA ONLY (CC-Dev1; remove all 3 before beta).
# Production deploys MUST leave these unset. The feature is also
# hard-gated by NODE_ENV !== "production".
# ──────────────────────────────────────────────────────────────

# Master kill-switch. Must literally equal "true" for any
# impersonation code path to execute.
NEXT_PUBLIC_ENABLE_IMPERSONATION=true

# Comma-separated Clerk user IDs allowed to impersonate. Re-checked
# on every request — not just at sign-in.
IMPERSONATION_ADMIN_USER_IDS=user_xxx,user_yyy

# 32+ bytes of entropy. Used to HMAC-sign the imp_user_id cookie.
# Generate with:  openssl rand -hex 32
IMPERSONATION_COOKIE_SECRET=
